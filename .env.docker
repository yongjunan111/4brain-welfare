# =============================================================================
# Docker Compose 전용 환경변수 (.env.docker)
# Docker에서만 달라지는 값만 override — API 키는 루트 .env에서 주입됨
# =============================================================================

# --- DB ---
DB_HOST=db
DB_PORT=5432
DB_NAME=welfare
DB_USER=welfare_user
DB_PASSWORD=welfare1234
# Postgres 컨테이너용 (DB_*와 값을 동일하게 유지할 것)
POSTGRES_DB=welfare
POSTGRES_USER=welfare_user
POSTGRES_PASSWORD=welfare1234

# --- Django ---
DJANGO_SECRET_KEY=docker-dev-secret-key-change-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=backend,localhost,0.0.0.0,127.0.0.1,*
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3002,http://100.69.81.51:3000,http://100.69.81.51:3001,http://100.69.81.51:3002,http://welfarecompass.kro.kr:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000,http://100.69.81.51:8000,http://100.69.81.51,http://welfarecompass.kro.kr:3000,http://welfarecompass.kro.kr:8000

# --- MCP ---
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- MCP Server URL ---
MCP_SERVER_URL=http://mcp:8001

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=1028765028301-ehtn2pmbr4n90c3gc00aiea7ha2shg0q.apps.googleusercontent.com
NEXT_PUBLIC_KAKAO_MAP_API_KEY=dff2f63c64a181703a7fa1fa68263c0b