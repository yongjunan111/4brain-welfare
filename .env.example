# =============================================================================
# 복지나침반 환경변수 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값을 채우세요: cp .env.example .env
# =============================================================================

# --- DB (로컬 개발용) ---
DB_NAME=welfare
DB_USER=welfare_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=django-insecure-local-dev
DJANGO_DEBUG=True

# --- API Keys ---
YOUTH_API_KEY=
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
# --- LangFuse (선택) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- MCP ---
MCP_TRANSPORT=sse
MCP_HOST=127.0.0.1
MCP_PORT=8001

# --- 챗봇 ---
CHAT_LLM_TIMEOUT_SECONDS=60
CHAT_LLM_MAX_RETRIES=2

# --- 프론트엔드 URL ---
FRONTEND_URL=http://localhost:3000

# --- 검색 ---
SEARCH_BACKEND=direct
USE_RERANKER=false
