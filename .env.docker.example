# =============================================================================
# Docker Compose 전용 환경변수 템플릿
# 복사 후 API 키 채워서 사용: cp .env.docker.example .env.docker
# =============================================================================

# --- DB ---
DB_HOST=db
DB_PORT=5432
DB_NAME=welfare
DB_USER=welfare_user
DB_PASSWORD=welfare1234
# Postgres 컨테이너용 — 반드시 위 DB_* 값과 동일해야 합니다.
# 불일치 시 backend/llm 컨테이너가 DB 연결에 실패합니다.
POSTGRES_DB=welfare
POSTGRES_USER=welfare_user
POSTGRES_PASSWORD=welfare1234

# --- Django ---
DJANGO_SECRET_KEY=docker-dev-secret-key-change-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=backend,localhost,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000

# --- MCP ---
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_SERVER_URL=http://mcp:8001

# --- API Keys (필수: 각자 발급받은 키 입력) ---
YOUTH_API_KEY=your-youth-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Langfuse (선택) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://langfuse-web:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
